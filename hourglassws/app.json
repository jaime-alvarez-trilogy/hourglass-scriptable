{
  "expo": {
    "name": "Hourglass",
    "slug": "hourglassws",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hourglassws",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jalvarez0907.hourglass",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.jalvarez0907.hourglass.widgets"
        ]
      },
      "buildNumber": "1"
    },
    "android": {
      "package": "com.jalvarez0907.hourglass",
      "adaptiveIcon": {
        "backgroundColor": "#0D1117",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.com.jalvarez0907.hourglass.widgets",
          "widgets": [
            {
              "name": "HourglassWidget",
              "displayName": "Hourglass",
              "description": "Track your weekly hours and earnings",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "systemLarge"
              ],
              "contentMarginsDisabled": true
            }
          ]
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "HourglassWidget",
              "label": "Hourglass"
            }
          ],
          "widgetTaskHandler": "./src/widgets/android/widgetTaskHandler"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0D0C14",
          "dark": {
            "backgroundColor": "#0D0C14"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#00FF88"
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "updates": {
      "url": "https://u.expo.dev/4ad8a6bd-aec2-45a5-935f-5598d47b605d"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "ENABLE_NATIVE_TABS": true,
      "ENABLE_SHARED_ELEMENT_TRANSITIONS": true,
      "router": {},
      "eas": {
        "projectId": "4ad8a6bd-aec2-45a5-935f-5598d47b605d"
      }
    },
    "owner": "jalvarez0907"
  }
}
